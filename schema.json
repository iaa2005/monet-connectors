{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Code Monet connector manifest (schema 1)",
  "type": "object",
  "required": ["schema", "id", "name", "company", "description", "version", "auth", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,40}$" },
    "name": { "type": "string", "minLength": 1 },
    "company": { "type": "string" },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "credUrl": { "type": "string", "format": "uri" },
    "credLabel": { "type": "string" },
    "note": { "type": "string" },
    "promptHint": { "type": "string" },
    "setupSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "urlLabel": { "type": "string" }
        }
      }
    },
    "auth": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "fields"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "password" },
            "fields": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/definitions/authField" }
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "field"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "token" },
            "field": { "$ref": "#/definitions/authField" }
          }
        }
      ]
    },
    "capabilities": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "mail": {
          "type": "object",
          "required": ["imap", "smtp"],
          "additionalProperties": false,
          "properties": {
            "imap": { "$ref": "#/definitions/tlsHost" },
            "smtp": { "$ref": "#/definitions/tlsHost" },
            "authHint": { "type": "string" }
          }
        },
        "webdav": { "$ref": "#/definitions/httpsEndpoint" },
        "caldav": { "$ref": "#/definitions/davEndpoint" },
        "carddav": { "$ref": "#/definitions/davEndpoint" },
        "mcp": {
          "type": "object",
          "required": ["command", "args", "envKey"],
          "additionalProperties": false,
          "properties": {
            "command": { "enum": ["npx", "uvx"] },
            "args": { "type": "array", "items": { "type": "string" } },
            "envKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  },
  "definitions": {
    "authField": {
      "type": "object",
      "required": ["key", "label"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "placeholder": { "type": "string" },
        "secret": { "type": "boolean" },
        "mono": { "type": "boolean" }
      }
    },
    "tlsHost": {
      "type": "object",
      "required": ["host", "port", "secure"],
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string", "pattern": "^[a-zA-Z0-9.-]+$" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "secure": { "const": true }
      }
    },
    "httpsEndpoint": {
      "type": "object",
      "required": ["url"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "pattern": "^https://" },
        "authHint": { "type": "string" }
      }
    },
    "davEndpoint": {
      "type": "object",
      "required": ["url"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "pattern": "^https://" },
        "principalTemplate": { "type": "string", "pattern": "^https://" },
        "authHint": { "type": "string" }
      }
    }
  }
}
